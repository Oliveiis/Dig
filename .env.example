# ============================================================
# Backend (server-side only) — used by api/*.ts on Vercel
# ============================================================

# SerpAPI key — used by /api/dig to fetch Google Maps place data.
# Get one at https://serpapi.com
SERPAPI_KEY=

# DeepSeek API key — used by /api/dig to generate hook_tag / why_worth_it copy.
# Get one at https://platform.deepseek.com
# Optional: without it, /api/dig falls back to rule-based tag/why_worth_it.
DEEPSEEK_API_KEY=

# ============================================================
# Frontend (Vite, build-time injected — prefixed with VITE_)
# ============================================================

# Google Maps JS API key — used by @vis.gl/react-google-maps for map rendering.
VITE_GOOGLE_MAPS_API_KEY=

# ============================================================
# Legacy / AI Studio only (not required for Vercel)
# ============================================================

# GEMINI_API_KEY and APP_URL are auto-injected by Google AI Studio at runtime.
# Vercel deployments do not use them — left here for AI Studio compatibility.
# GEMINI_API_KEY=
# APP_URL=
